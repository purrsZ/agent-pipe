# 飞书应用凭证（在 open.feishu.cn 应用后台获取）
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxx

# 仅允许这些 open_id 使用 bot（逗号分隔），防止误加好友被滥用
# 在飞书开发者后台 → 通讯录 API 查自己的 open_id
ALLOWED_OPEN_IDS=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 项目模式 cwd 白名单（冒号分隔）；/new --cwd 只能指向这些前缀下的路径
ALLOWED_CWD_PREFIXES=/path/to/your/code:/path/to/other/workspace

# 默认 agent：/new 不带 --agent 时用哪个（claude | codex）
DEFAULT_AGENT=claude

# Claude Code CLI 可执行文件路径（默认从 PATH 查找）
CLAUDE_PATH=claude
CLAUDE_MODEL=claude-opus-4-7[1m]
# effort level: low | medium | high | xhigh | max
CLAUDE_EFFORT=xhigh

# Codex CLI 可执行文件路径
CODEX_PATH=codex
CODEX_MODEL=gpt-5.1-codex
# 可选：low | medium | high
# CODEX_REASONING_EFFORT=high

# 热进程池容量上限（只对 claude 等长连接 agent 生效；codex 每轮 spawn 不占槽）
MAX_HOT=4

# 日志级别（debug | info | warn | error）
LOG_LEVEL=info

# 数据根目录（支持 ~）
DATA_DIR=~/.agent-pipe
